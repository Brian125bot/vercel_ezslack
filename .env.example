# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Cloud Tasks Configuration
GCP_PROJECT_ID=
GCP_LOCATION="us-west1"
CLOUD_TASKS_QUEUE_NAME="slack-agent-queue"
INTERNAL_API_SECRET="generate-a-secure-random-string-here"


# SQL Database Configuration (Optional)
# If set, enables durable PostgreSQL storage for agent goals, runs, logs, and memory.
# Cloud SQL Connection Name (e.g. project:region:instance)
CLOUD_SQL_CONNECTION_NAME=
# Standard PostgreSQL fallback
DATABASE_URL=
# SQL_HOST, SQL_USER, SQL_PASSWORD, SQL_DB_NAME
# Standard PostgreSQL connection parameters
SQL_HOST=
SQL_USER=
SQL_PASSWORD=
SQL_DB_NAME=
DB_USER=
DB_PASSWORD=
DB_NAME=

# Admin connection for Drizzle Kit specifically (schema migrations)
SQL_ADMIN_CONNECTION_NAME=
SQL_ADMIN_DATABASE_URL=
