# ── Required ──────────────────────────────────────────────────────────────

# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# SLACK_BOT_TOKEN: xoxb- token for posting messages and Block Kit approvals.
SLACK_BOT_TOKEN="xoxb-myslackbottoken"

# SLACK_SIGNING_SECRET: Slack app signing secret for request signature verification.
SLACK_SIGNING_SECRET="my_slack_signing_secret"

# DASHBOARD_PASSWORD: HTTP Basic Auth password for the /api/* admin dashboard.
DASHBOARD_PASSWORD="my_dashboard_password"

# APP_URL: The public URL where this app is hosted.
# Used for self-referential webhook callbacks and workflow triggers.
APP_URL="https://your-app.vercel.app"


# ── Database (optional — skip for in-memory-only mode) ─────────────────────

# Vercel Postgres / Neon connection string.
# Append ?pgbouncer=true when using connection poolers (Neon, Supabase).
DATABASE_URL="postgresql://user:pass@host:port/db"

# SSL mode: set to "true" when DATABASE_URL requires SSL (default: false)
DATABASE_SSL="true"

# Pool config (optional)
DB_POOL_MAX="5"
DB_CONNECTION_TIMEOUT="10000"


# ── Agent tuning (optional) ──────────────────────────────────────────────

# Model override. Allowed: gemini-2.5-flash, gemini-2.0-flash, gemini-1.5-flash
# SELECTED_MODEL="gemini-2.5-flash"

# Max concurrent direct-reply handlers (default: 5)
DIRECT_REPLY_CONCURRENCY="5"

# Wall-clock timeout per run in ms (default: 45000 — leaves 15s margin on Vercel Pro 60s)
RUN_TIMEOUT_MS="45000"

# Lease duration in seconds for worker claim (default: 120)
WORKER_LEASE_SECONDS="120"

# Gemini API timeout in ms (default: 30000)
GEMINI_TIMEOUT_MS="30000"


# ── Vercel deployment (optional) ──────────────────────────────────────────

# Vercel Automation Bypass Secret (for preview deployment protection bypass)
# VERCEL_AUTOMATION_BYPASS_SECRET="your-vercel-bypass-secret"

# Vercel Cron authentication secret — must match value set in vercel.json
# CRON_SECRET="your-vercel-cron-secret"


# ── External Adapters (optional) ──────────────────────────────────────────

# GitHub Issues — https://github.com
# Optional. When set, enables the github.createIssue tool.
GITHUB_TOKEN=

# Email Webhook — Custom SMTP relay
# Optional. When set, enables the email.send tool.
EMAIL_WEBHOOK_URL=

# Web Search (Tavily) — https://app.tavily.com
# Optional. When set, enables the search.query tool (risk level: read, no approval required).
TAVILY_API_KEY=
