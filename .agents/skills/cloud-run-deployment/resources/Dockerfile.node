# ==============================================================================
# STAGE 1: Build & Compile Assets
# ==============================================================================
FROM node:22-alpine AS builder

WORKDIR /usr/src/app

# Copy package files first to leverage Docker layer caching
COPY package*.json ./

# Install all dependencies (including devDependencies required for compilation)
RUN npm ci

# Copy the rest of the application source code
COPY . .

# Build application assets (e.g. bundle TypeScript, compile React/Vite assets, etc.)
RUN npm run build --if-present


# ==============================================================================
# STAGE 2: Lightweight Production Runtime
# ==============================================================================
FROM node:22-alpine AS runner

WORKDIR /usr/src/app

# Set production environment variable
ENV NODE_ENV=production

# Copy package management files for production-only installation
COPY package*.json ./

# Install only production-tier dependencies to minimize the image footprint
RUN npm ci --only=production

# Copy compiled target assets from the builder stage
COPY --from=builder /usr/src/app/dist ./dist

# Use non-privileged node user for executing the process
USER node

# Expose standard Cloud Run ingress port variable
EXPOSE 8080

# Start server using the production start script
CMD ["npm", "run", "start"]
