{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/:route(status|model|logs|agent|slack|health)/:path*",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/poll",
      "schedule": "0 9 * * *"
    }
  ]
}
